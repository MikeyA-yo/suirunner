---

<style is:global>
  #hero-terminal {
    font-family: var(--sl-font-mono, 'Courier New', monospace);
    font-size: 0.78rem;
    line-height: 1.55;
    border-radius: 0.55rem;
    overflow: hidden;
    border: 1px solid #586e75;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.7);
    width: 100%;
  }

  .t-bar {
    background: #073642;
    padding: 0.45rem 0.8rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border-bottom: 1px solid #586e75;
    user-select: none;
  }

  .t-dots { display: flex; gap: 0.35rem; }

  .t-dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    display: inline-block;
  }
  .t-dot-r { background: #dc322f; }
  .t-dot-y { background: #b58900; }
  .t-dot-g { background: #859900; }

  .t-title {
    flex: 1;
    text-align: center;
    color: #586e75;
    font-size: 0.72rem;
    letter-spacing: 0.04em;
  }

  .t-body {
    background: #002b36;
    padding: 0.8rem 0.95rem;
    height: 295px;
    overflow: hidden;
  }

  .t-hist {
    transition: opacity 0.25s ease;
  }

  .t-row { white-space: pre; min-height: 1em; }

  .t-row-prompt { color: #839496; }
  .t-p-sym      { color: #268bd2; }
  .t-p-cmd      { color: #93a1a1; }

  .t-out      { color: #657b83; }
  .t-out-ok   { color: #859900; }
  .t-out-info { color: #268bd2; }

  .t-cur-line {
    display: flex;
    align-items: baseline;
  }

  .t-sym { color: #268bd2; margin-right: 0.35em; flex-shrink: 0; }
  .t-in  { color: #93a1a1; white-space: pre; }

  .t-cur {
    color: #268bd2;
    animation: t-blink 1.1s step-end infinite;
    margin-left: 1px;
  }

  @keyframes t-blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }
</style>

<script>
  const root = document.getElementById('hero-terminal');
  if (!root) throw new Error('[TerminalAnimation] #hero-terminal not found');

  root.innerHTML = `
    <div class="t-bar">
      <div class="t-dots">
        <span class="t-dot t-dot-r"></span>
        <span class="t-dot t-dot-y"></span>
        <span class="t-dot t-dot-g"></span>
      </div>
      <span class="t-title">sui-runner — terminal</span>
    </div>
    <div class="t-body">
      <div class="t-hist" id="t-hist"></div>
    </div>
  `;

  const hist = document.getElementById('t-hist') as HTMLElement;

  const MAX_ROWS = 13;
  const sleep = (ms: number) => new Promise<void>((r) => setTimeout(r, ms));

  const sequences = [
    {
      cmd: 'sui-runner --help',
      lines: [
        { text: 'sui-runner helps you set up, build, and manage', cls: 't-out' },
        { text: 'projects on the Sui blockchain.', cls: 't-out' },
        { text: 'Run any subcommand with --help for detailed usage.', cls: 't-out' },
        { text: '', cls: 't-out' },
        { text: 'Usage: sui-runner [OPTIONS] <COMMAND>', cls: 't-out' },
        { text: '', cls: 't-out' },
        { text: 'Commands:', cls: 't-out' },
        { text: '  init       Initialise a new Sui project', cls: 't-out' },
        { text: '  check      Check that required tools are installed', cls: 't-out' },
        { text: '  wallet     Manage Sui wallets', cls: 't-out' },
        { text: '  build      Compile (or test) a Move package', cls: 't-out' },
        { text: '  dashboard  Live TUI dashboard', cls: 't-out' },
        { text: '  deploy     Deploy or Publish a Move package', cls: 't-out' },
        { text: '', cls: 't-out' },
        { text: 'Options:', cls: 't-out' },
        { text: '  -v, --verbose   Enable verbose output', cls: 't-out' },
        { text: '  -h, --help      Print help', cls: 't-out' },
        { text: '  -V, --version   Print version', cls: 't-out' },
      ],
    },
    {
      cmd: 'sui-runner check',
      lines: [
        { text: 'Checking required tools...', cls: 't-out'    },
        { text: '',                           cls: 't-out'    },
        { text: '  [ok]  sui',               cls: 't-out-ok' },
        { text: '  [ok]  git',               cls: 't-out-ok' },
        { text: '  [ok]  cargo',             cls: 't-out-ok' },
        { text: '',                           cls: 't-out'    },
        { text: 'All tools found.',           cls: 't-out-ok' },
      ],
    },
    {
      cmd: 'sui-runner init -n suidash',
      lines: [
        { text: "Initialising project 'suidash' on testnet", cls: 't-out-info' },
        { text: 'Created suidash\\sui-runner.json',           cls: 't-out'     },
        { text: 'Done. Run cd suidash',                       cls: 't-out-ok'  },
        { text: 'Run `sui-runner check` to verify your toolchain.', cls: 't-out' },
      ],
    },
  ];

  function trimHist() {
    while (hist.children.length > MAX_ROWS) {
      hist.removeChild(hist.firstElementChild as Element);
    }
  }

  function addRow(text: string, cls: string) {
    const el = document.createElement('div');
    el.className = `t-row ${cls}`;
    el.textContent = text;
    hist.appendChild(el);
    trimHist();
  }

  async function clearHist() {
    hist.style.opacity = '0';
    await sleep(250);
    hist.innerHTML = '';
    hist.style.opacity = '1';
  }

  async function runSequence(seq: typeof sequences[0]) {
    // Add the active typing line at the current position (top if hist is empty)
    const activeLine = document.createElement('div');
    activeLine.className = 't-cur-line';
    activeLine.innerHTML = '<span class="t-sym">$</span><span class="t-in"></span><span class="t-cur">▊</span>';
    hist.appendChild(activeLine);
    trimHist();

    const activeInput = activeLine.querySelector('.t-in') as HTMLElement;

    // Type command character by character
    for (const ch of seq.cmd) {
      activeInput.textContent += ch;
      await sleep(55 + Math.random() * 25);
    }
    await sleep(380);

    // Freeze the active line as a history row
    activeLine.className = 't-row t-row-prompt';
    activeLine.innerHTML = `<span class="t-p-sym">$</span> <span class="t-p-cmd">${seq.cmd}</span>`;

    // Stream output lines
    for (const line of seq.lines) {
      addRow(line.text, line.cls);
      await sleep(42);
    }

    await sleep(3000);
    await clearHist();
  }

  async function loop() {
    while (true) {
      for (const seq of sequences) {
        await runSequence(seq);
      }
    }
  }

  setTimeout(loop, 900);
</script>
